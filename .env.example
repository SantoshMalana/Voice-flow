# Copy this file to .env in the project root (same folder as package.json).
# The app also stores keys in %LOCALAPPDATA%\VoiceFlow\config.json after you save in Settings.

# Groq — required for Whisper transcription and most polish modes
# Get a key: https://console.groq.com/
GROQ_API_KEY=

# Optional: extra Groq keys for rotation / rate limits
# GROQ_API_KEY_2=
# GROQ_API_KEY_3=

# Cerebras — optional; used for Code mode (OpenAI-compatible API)
# Get a key: https://inference.cerebras.ai/ (or your Cerebras console)
CEREBRAS_API_KEY=

# Optional extras
# CEREBRAS_API_KEY_2=
# CEREBRAS_API_KEY_3=
